---
interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;

const navItems = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/features/', label: 'Features', key: 'features' },
  { href: '/security/', label: 'Security', key: 'security' },
  { href: '/docs/', label: 'Docs', key: 'docs' },
  { href: '/download/', label: 'Download', key: 'download' },
  { href: '/about/', label: 'About', key: 'about' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/95 backdrop-blur-sm border-b border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2">
        <span class="text-2xl">🗿</span>
        <span class="font-heading text-xl font-bold text-text-primary">Moaiy</span>
      </a>

      <div class="hidden md:flex items-center gap-6">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`font-body text-sm font-medium transition-colors ${
              currentPage === item.key
                ? 'text-accent-primary'
                : 'text-text-secondary hover:text-text-primary'
            }`}
          >
            {item.label}
          </a>
        ))}
      </div>

      <div class="hidden md:block">
        <a
          href="/download/"
          data-analytics-event="download_click"
          class="px-4 py-2 bg-accent-primary text-white font-semibold text-sm rounded-lg hover:bg-accent-secondary transition-colors"
        >
          Get Moaiy
        </a>
      </div>

      <button
        id="mobile-menu-button"
        class="md:hidden p-2 text-text-secondary hover:text-text-primary"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="md:hidden hidden pb-4">
      <div class="flex flex-col gap-3">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`font-body text-sm font-medium py-2 px-3 rounded-lg transition-colors ${
              currentPage === item.key
                ? 'bg-bg-tertiary text-accent-primary'
                : 'text-text-secondary hover:text-text-primary hover:bg-bg-tertiary'
            }`}
          >
            {item.label}
          </a>
        ))}
        <a
          href="/download/"
          data-analytics-event="download_click"
          class="mt-2 px-4 py-2 bg-accent-primary text-white font-semibold text-sm rounded-lg hover:bg-accent-secondary transition-colors text-center"
        >
          Get Moaiy
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  button?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
