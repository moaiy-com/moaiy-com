---
import Navigation from '../components/Navigation.astro';
import type { SeoSchema } from '../seo/page-config';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  ogImage?: string;
  robots?: string;
  schema?: SeoSchema[];
  currentPage?: string;
}

const {
  title,
  description,
  canonicalPath,
  ogImage = '/og-image.svg',
  robots = 'index, follow',
  schema = [],
  currentPage = '',
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://moaiy.com');
const normalizedPath =
  canonicalPath === '/' ? '/' : canonicalPath.endsWith('/') ? canonicalPath : `${canonicalPath}/`;
const canonicalUrl = new URL(normalizedPath, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();

const X_URL = 'https://x.com/moaiycom';
const GITHUB_URL = 'https://github.com/moaiy-com/moaiy';
const ETH_DONATION_ADDRESS = '0x7945C89E6Dfc83A10894f1d5149c1650fBa4Aa9c';
const RELEASES_URL = 'https://github.com/moaiy-com/moaiy/releases';

const footerLinks = [
  { href: '/download/', label: 'Download' },
  { href: '/docs/', label: 'Docs' },
  { href: '/security/', label: 'Security' },
  { href: '/features/', label: 'Features' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" />

    <title>{title}</title>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Moaiy" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="Moaiy open-source encryption project" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@moaiycom" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {schema.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-1EFMK5162Q"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        window.dataLayer.push(arguments);
      }
      window.gtag = window.gtag || gtag;
      window.gtag('js', new Date());
      window.gtag('config', 'G-1EFMK5162Q');

      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest('a[data-analytics-event]') : null;
        if (!target || !(target instanceof HTMLAnchorElement)) {
          return;
        }

        const eventName = target.dataset.analyticsEvent;
        if (!eventName) {
          return;
        }

        window.gtag('event', eventName, {
          link_url: target.href,
          link_text: (target.textContent || '').trim(),
          page_path: window.location.pathname,
        });
      });
    </script>
  </head>
  <body class="bg-bg-primary text-text-primary font-body antialiased">
    <a
      href="#content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded-md focus:bg-bg-tertiary focus:px-4 focus:py-2 focus:text-sm focus:text-text-primary focus:shadow-lg"
    >
      Skip to content
    </a>
    <Navigation currentPage={currentPage} />
    <div id="content" class="pt-20">
      <slot />
    </div>
    <footer class="border-t border-line-strong/70 bg-bg-primary/90">
      <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 gap-8 md:grid-cols-[1.3fr_1fr_1fr]">
          <div>
            <h2 class="mb-3 font-heading text-lg font-semibold text-text-primary">Moaiy</h2>
            <p class="max-w-md text-sm text-text-secondary">
              A simple app to encrypt files on macOS. Free and open source.
            </p>
            <p class="mt-3 break-all font-code text-xs text-text-tertiary">
              Donation (ETH): <span class="text-text-secondary">{ETH_DONATION_ADDRESS}</span>
            </p>
          </div>
          <div>
            <h2 class="mb-3 font-heading text-lg font-semibold text-text-primary">Core</h2>
            <div class="flex flex-col gap-2">
              {footerLinks.map((link) => (
                <a
                  href={link.href}
                  class="w-fit text-sm text-text-secondary transition-colors hover:text-accent-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-primary"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
          <div>
            <h2 class="mb-3 font-heading text-lg font-semibold text-text-primary">Project</h2>
            <div class="flex flex-col gap-2">
              <a
                href={RELEASES_URL}
                target="_blank"
                rel="noopener noreferrer"
                data-analytics-event="download_click"
                class="text-sm text-text-secondary transition-colors hover:text-accent-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-primary"
              >
                Releases
              </a>
              <a
                href={GITHUB_URL}
                target="_blank"
                rel="noopener noreferrer"
                data-analytics-event="github_click"
                class="text-sm text-text-secondary transition-colors hover:text-accent-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-primary"
              >
                GitHub
              </a>
              <a
                href={X_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-text-secondary transition-colors hover:text-accent-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-primary"
              >
                X (@moaiycom)
              </a>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Scope One';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url('/fonts/ScopeOne-Regular.ttf') format('truetype');
  }

  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  @layer components {
    .page-shell {
      @apply min-h-screen bg-bg-primary px-4 py-20;
    }

    .page-container {
      @apply mx-auto w-full max-w-6xl;
    }

    .page-container-narrow {
      @apply mx-auto w-full max-w-5xl;
    }

    .page-container-compact {
      @apply mx-auto w-full max-w-4xl;
    }

    .page-hero {
      @apply mb-14;
    }

    .page-title {
      @apply text-balance font-heading text-4xl font-bold text-text-primary md:text-5xl;
    }

    .page-subtitle {
      @apply mt-4 text-lg leading-relaxed text-text-secondary;
    }

    .surface-card {
      @apply rounded-xl border border-line-strong bg-bg-secondary/65 p-7 md:p-8;
    }

    .surface-card-strong {
      @apply rounded-xl border border-line-strong bg-bg-secondary/70 p-7 md:p-8;
    }

    .surface-card-soft {
      @apply rounded-xl border border-line-strong bg-bg-secondary/55 p-6;
    }

    .link-grid {
      @apply mt-12 grid grid-cols-1 gap-4 md:grid-cols-3;
    }

    .link-card {
      @apply rounded-lg border border-line-strong bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary;
    }

    .link-card-title {
      @apply block font-heading text-lg text-text-primary;
    }

    .link-card-description {
      @apply mt-2 block text-sm text-text-secondary;
    }

    .code-block {
      @apply mt-5 space-y-2 rounded-lg bg-bg-tertiary p-4 font-code text-sm text-text-secondary;
    }

    .list-compact {
      @apply mt-5 space-y-2 text-sm leading-relaxed text-text-secondary;
    }

    .btn-primary {
      @apply inline-flex items-center rounded-lg bg-accent-primary px-5 py-3 text-sm font-semibold text-bg-primary transition-colors hover:bg-accent-secondary;
    }

    .btn-secondary {
      @apply inline-flex items-center rounded-lg border border-line-subtle px-5 py-3 text-sm font-semibold text-text-primary transition-colors hover:border-accent-primary/60 hover:text-accent-primary;
    }
  }

  html {
    scroll-behavior: smooth;
    color-scheme: light;
    font-synthesis: none;
  }

  body {
    @apply min-h-screen;
  }

  /* Scope One only ships regular weight; pin utility-weight combos to avoid fake bold rendering. */
  .font-heading.font-medium,
  .font-heading.font-semibold,
  .font-heading.font-bold,
  .font-body.font-medium,
  .font-body.font-semibold,
  .font-body.font-bold,
  .font-code.font-medium,
  .font-code.font-semibold,
  .font-code.font-bold {
    font-weight: 400;
  }

  ::selection {
    @apply bg-accent-primary text-bg-primary;
  }

  :where(a, button, summary, [role='button']):focus-visible {
    @apply outline-none ring-2 ring-accent-primary/70 ring-offset-2 ring-offset-bg-primary;
  }

  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }

  ::-webkit-scrollbar-track {
    @apply bg-bg-secondary;
  }

  ::-webkit-scrollbar-thumb {
    @apply bg-accent-primary rounded-full;
  }

  ::-webkit-scrollbar-thumb:hover {
    @apply bg-accent-secondary;
  }
</style>
