---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Moaiy - Encryption Made Simple. 安全简单的加密工具，为每个人设计。" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- SEO -->
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://moaiy.com" />
    <meta name="twitter:card" content="summary_large_image" />
    
    <!-- Theme Color -->
    <meta name="theme-color" content="#0A0E27" />
  </head>
  <body class="bg-bg-primary text-text-primary font-body antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;
  
  /* Custom Global Styles */
  html {
    scroll-behavior: smooth;
  }
  
  body {
    @apply min-h-screen;
  }
  
  /* Selection */
  ::selection {
    @apply bg-accent-primary text-bg-primary;
  }
  
  /* Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  
  ::-webkit-scrollbar-track {
    @apply bg-bg-secondary;
  }
  
  ::-webkit-scrollbar-thumb {
    @apply bg-accent-primary rounded-full;
  }
  
  ::-webkit-scrollbar-thumb:hover {
    @apply bg-accent-secondary;
  }
</style>
