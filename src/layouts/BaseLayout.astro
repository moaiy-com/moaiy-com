---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Moaiy - Encryption Made Simple. Secure and easy-to-use encryption tool designed for everyone." } = Astro.props;
const X_URL = 'https://x.com/moaiycom';
const ETH_DONATION_ADDRESS = '0x7945C89E6Dfc83A10894f1d5149c1650fBa4Aa9c';
const canonicalUrl = Astro.url;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    
    <!-- Theme Color -->
    <meta name="theme-color" content="#0A0E27" />
    
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-1EFMK5162Q"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-1EFMK5162Q');
    </script>
  </head>
  <body class="bg-bg-primary text-text-primary font-body antialiased">
    <slot />
    <footer class="border-t border-gray-800 bg-bg-primary/95">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
        <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
          <a
            href={X_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-text-secondary hover:text-accent-primary transition-colors"
          >
            X: @moaiycom
          </a>
          <p class="font-code text-xs text-text-tertiary break-all">
            ETH Donation: <span class="text-text-secondary">{ETH_DONATION_ADDRESS}</span>
          </p>
          <div class="flex items-center gap-4 text-xs">
            <a href="/privacy/" class="font-body text-text-secondary hover:text-accent-primary transition-colors">
              Privacy
            </a>
            <a href="/terms/" class="font-body text-text-secondary hover:text-accent-primary transition-colors">
              Terms
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;
  
  /* Custom Global Styles */
  html {
    scroll-behavior: smooth;
  }
  
  body {
    @apply min-h-screen;
  }
  
  /* Text Selection */
  ::selection {
    @apply bg-accent-primary text-bg-primary;
  }
  
  /* Custom Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  
  ::-webkit-scrollbar-track {
    @apply bg-bg-secondary;
  }
  
  ::-webkit-scrollbar-thumb {
    @apply bg-accent-primary rounded-full;
  }
  
  ::-webkit-scrollbar-thumb:hover {
    @apply bg-accent-secondary;
  }
</style>
