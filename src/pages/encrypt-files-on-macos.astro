---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.encryptFilesOnMacos;
const releaseUrl = 'https://github.com/moaiy-com/moaiy/releases';
---

<BaseLayout {...seo}>
  <main class="min-h-screen bg-bg-primary px-4 py-20">
    <div class="mx-auto max-w-4xl">
      <header class="mx-auto mb-14 max-w-3xl">
        <h1 class="text-balance font-heading text-4xl font-bold text-text-primary md:text-5xl">
          Encrypt files on macOS with Moaiy
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-text-secondary">
          A compact workflow for key generation, encryption, and trusted distribution.
        </p>
      </header>

      <section class="space-y-5">
        <article class="rounded-xl border border-gray-800 bg-bg-secondary/70 p-6 md:p-7">
          <h2 class="font-heading text-2xl font-semibold text-text-primary">1. Get a trusted build</h2>
          <p class="mt-3 text-sm leading-relaxed text-text-secondary">Download only from official GitHub Releases.</p>
          <a
            href={releaseUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-analytics-event="download_click"
            class="mt-4 inline-flex items-center rounded-lg bg-accent-primary px-4 py-2 text-sm font-semibold text-bg-primary transition-colors hover:bg-accent-secondary"
          >
            Open Releases
          </a>
        </article>

        <article class="rounded-xl border border-gray-800 bg-bg-secondary/65 p-6 md:p-7">
          <h2 class="font-heading text-2xl font-semibold text-text-primary">2. Generate a key pair</h2>
          <div class="mt-4 rounded-lg bg-bg-tertiary p-4 font-code text-sm text-text-secondary">
            <div><span class="text-accent-primary">$</span> moaiy key generate</div>
          </div>
        </article>

        <article class="rounded-xl border border-gray-800 bg-bg-secondary/65 p-6 md:p-7">
          <h2 class="font-heading text-2xl font-semibold text-text-primary">3. Encrypt a file</h2>
          <div class="mt-4 space-y-2 rounded-lg bg-bg-tertiary p-4 font-code text-sm text-text-secondary">
            <div><span class="text-accent-primary">$</span> moaiy encrypt contracts.zip --recipient partner@example.com</div>
            <div><span class="text-accent-primary">$</span> moaiy encrypt contracts.zip --password</div>
          </div>
        </article>

        <article class="rounded-xl border border-gray-800 bg-bg-secondary/65 p-6 md:p-7">
          <h2 class="font-heading text-2xl font-semibold text-text-primary">4. Verify and share</h2>
          <p class="mt-3 text-sm leading-relaxed text-text-secondary">
            Verify release checksums, then share encrypted artifacts through your preferred channel.
          </p>
          <a href="/verification/" class="mt-4 inline-flex text-sm font-semibold text-accent-primary hover:underline">Read verification guide</a>
        </article>
      </section>

      <section class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-2">
        <a href="/docs/" class="rounded-lg border border-gray-800 bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary">
          <h2 class="font-heading text-lg text-text-primary">Full Docs</h2>
          <p class="mt-2 text-sm text-text-secondary">Expanded command patterns and FAQs.</p>
        </a>
        <a href="/gpg-tools-alternative/" class="rounded-lg border border-gray-800 bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary">
          <h2 class="font-heading text-lg text-text-primary">Compare Alternatives</h2>
          <p class="mt-2 text-sm text-text-secondary">Evaluate complexity versus classic GPG tools.</p>
        </a>
      </section>
    </div>
  </main>
</BaseLayout>
