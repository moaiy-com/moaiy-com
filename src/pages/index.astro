---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroScene from '../components/HeroScene.jsx';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.home;
---

<BaseLayout {...seo}>
  <main class="relative isolate min-h-screen overflow-hidden bg-bg-primary">
    <div id="hero-canvas" class="pointer-events-none absolute inset-0 z-0">
      <HeroScene client:idle />
    </div>

    <div class="relative z-10 flex flex-col items-center justify-center min-h-screen px-4">
      <div class="flex flex-col items-center md:-translate-x-14 lg:-translate-x-24 transition-transform duration-300 max-w-3xl text-center">
        <h1 class="font-heading text-5xl md:text-7xl font-bold text-text-primary mb-4 animate-fade-in-up">
          Open-Source Encryption Made Practical
        </h1>
        <p class="font-heading text-xl md:text-3xl font-light text-accent-primary mb-4 animate-fade-in-up" style="animation-delay: 0.2s">
          Moaiy helps teams encrypt files with less friction.
        </p>
        <p class="hero-tagline font-body text-lg md:text-xl animate-fade-in-up" style="animation-delay: 0.4s;">
          Transparent project · Local-first workflows · Security-focused docs
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mt-10 animate-fade-in-up" style="animation-delay: 0.6s">
          <a
            href="/download/"
            data-analytics-event="download_click"
            class="px-8 py-4 bg-accent-primary text-white font-semibold rounded-lg transition-all duration-300 hover:bg-accent-secondary hover:-translate-y-1"
          >
            Download & Verify
          </a>
          <a
            href="/docs/"
            data-analytics-event="docs_cta_click"
            class="px-8 py-4 border-2 border-accent-primary text-accent-primary font-semibold rounded-lg transition-all duration-300 hover:bg-accent-primary hover:text-white"
          >
            Read Task Docs
          </a>
          <a
            href="https://github.com/moaiy-com/moaiy"
            target="_blank"
            rel="noopener noreferrer"
            data-analytics-event="github_click"
            class="px-8 py-4 border-2 border-text-tertiary text-text-secondary font-semibold rounded-lg transition-all duration-300 hover:border-text-secondary hover:text-text-primary"
          >
            View Source
          </a>
        </div>
      </div>

      <div class="absolute bottom-8 animate-bounce">
        <svg class="w-6 h-6 text-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </div>
  </main>

  <section class="bg-bg-secondary py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-heading text-4xl md:text-5xl font-bold text-text-primary text-center mb-16">
        Why teams choose Moaiy
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <article class="bg-bg-tertiary rounded-xl p-8 border border-gray-800 transition-all duration-300 hover:border-accent-primary/50 hover:-translate-y-2 hover:shadow-2xl">
          <h3 class="font-heading text-2xl font-semibold text-text-primary mb-4">Clear encryption flow</h3>
          <p class="font-body text-text-secondary leading-relaxed">
            Moaiy focuses on practical encrypt/decrypt workflows so teams can protect files without memorizing complex command chains.
          </p>
        </article>

        <article class="bg-bg-tertiary rounded-xl p-8 border border-gray-800 transition-all duration-300 hover:border-accent-primary/50 hover:-translate-y-2 hover:shadow-2xl">
          <h3 class="font-heading text-2xl font-semibold text-text-primary mb-4">Open-source trust model</h3>
          <p class="font-body text-text-secondary leading-relaxed">
            Security claims are backed by a public repository, documented release channels, and auditable project history.
          </p>
        </article>

        <article class="bg-bg-tertiary rounded-xl p-8 border border-gray-800 transition-all duration-300 hover:border-accent-primary/50 hover:-translate-y-2 hover:shadow-2xl">
          <h3 class="font-heading text-2xl font-semibold text-text-primary mb-4">Native macOS availability</h3>
          <p class="font-body text-text-secondary leading-relaxed">
            Current release focus is macOS. Other platforms are tracked in roadmap and release notes rather than pre-announced as shipped.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="bg-gradient-to-b from-bg-secondary to-bg-primary py-20 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="font-heading text-4xl md:text-5xl font-bold text-text-primary mb-8">
        Start with the exact workflow you need
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left">
        <a href="/encrypt-files-on-macos/" class="bg-bg-tertiary rounded-lg p-6 border border-gray-800 hover:border-accent-primary/50 transition-colors">
          <h3 class="font-heading text-xl text-text-primary mb-2">Encrypt files on macOS</h3>
          <p class="font-body text-sm text-text-secondary">Step-by-step guide for local file encryption and sharing.</p>
        </a>
        <a href="/openpgp-made-simple/" class="bg-bg-tertiary rounded-lg p-6 border border-gray-800 hover:border-accent-primary/50 transition-colors">
          <h3 class="font-heading text-xl text-text-primary mb-2">OpenPGP made simple</h3>
          <p class="font-body text-sm text-text-secondary">Understand core concepts without losing technical control.</p>
        </a>
        <a href="/gpg-tools-alternative/" class="bg-bg-tertiary rounded-lg p-6 border border-gray-800 hover:border-accent-primary/50 transition-colors">
          <h3 class="font-heading text-xl text-text-primary mb-2">Evaluate GPG alternatives</h3>
          <p class="font-body text-sm text-text-secondary">Compare workflow complexity and operational fit for your team.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-tagline {
    color: var(--hero-tagline-color, rgba(249, 250, 251, 0.95));
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.25);
    transition: color 220ms ease;
  }
</style>
