---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroScene from '../components/HeroScene.jsx';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.home;
const releaseUrl = 'https://github.com/moaiy-com/moaiy/releases';
const repositoryUrl = 'https://github.com/moaiy-com/moaiy';
---

<BaseLayout {...seo}>
  <main class="relative isolate min-h-screen overflow-hidden bg-bg-primary">
    <div id="hero-canvas" class="pointer-events-none absolute inset-0 z-0">
      <HeroScene client:media="(min-width: 768px)" />
    </div>
    <div class="pointer-events-none absolute inset-0 z-[1] bg-gradient-to-b from-bg-primary/50 via-bg-primary/30 to-bg-primary/85"></div>

    <div class="relative z-10 flex min-h-screen items-center px-4 py-20">
      <div class="mx-auto w-full max-w-6xl">
        <div class="max-w-2xl text-center md:-translate-x-16 md:text-left lg:-translate-x-20">
          <p class="mb-4 inline-flex items-center rounded-full border border-accent-primary/30 bg-bg-primary/40 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-accent-primary/90 backdrop-blur-sm">
            Open-Source • Local First
          </p>
          <h1 class="text-balance font-heading text-4xl font-bold leading-tight text-text-primary md:text-6xl animate-fade-in-up">
            Encrypt Files With Less Friction
          </h1>
          <p class="mt-5 max-w-xl text-lg leading-relaxed text-text-secondary md:text-xl animate-fade-in-up" style="animation-delay: 0.12s;">
            Moaiy is a native macOS app for practical OpenPGP workflows, with public code and verifiable releases.
          </p>
          <p class="hero-muted mt-4 text-sm font-medium uppercase tracking-[0.1em] animate-fade-in-up" style="animation-delay: 0.18s;">
            Transparent repository · Verified release channel · Security-first docs
          </p>

          <div class="mt-9 flex flex-col gap-3 sm:flex-row animate-fade-in-up" style="animation-delay: 0.24s">
            <a
              href={releaseUrl}
              target="_blank"
              rel="noopener noreferrer"
              data-analytics-event="download_click"
              class="inline-flex items-center justify-center rounded-lg bg-accent-primary px-6 py-3 text-base font-semibold text-bg-primary transition-colors hover:bg-accent-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-primary"
            >
              Download
            </a>
            <a
              href="/docs/"
              data-analytics-event="docs_cta_click"
              class="inline-flex items-center justify-center rounded-lg border border-gray-500/70 px-6 py-3 text-base font-semibold text-text-primary transition-colors hover:border-accent-primary/60 hover:text-accent-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-primary"
            >
              Read Docs
            </a>
          </div>
          <a
            href={repositoryUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-analytics-event="github_click"
            class="mt-4 inline-flex items-center text-sm font-semibold text-text-secondary transition-colors hover:text-text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-primary animate-fade-in-up"
            style="animation-delay: 0.3s;"
          >
            View on GitHub
          </a>
          <div class="mt-10 grid grid-cols-1 gap-3 sm:grid-cols-3 animate-fade-in-up" style="animation-delay: 0.36s;">
            <div class="rounded-lg border border-gray-700/80 bg-bg-primary/55 px-4 py-3 text-center backdrop-blur-sm md:text-left">
              <p class="text-xs font-semibold uppercase tracking-[0.08em] text-text-tertiary">Platform</p>
              <p class="mt-1 text-sm font-semibold text-text-primary">macOS</p>
            </div>
            <div class="rounded-lg border border-gray-700/80 bg-bg-primary/55 px-4 py-3 text-center backdrop-blur-sm md:text-left">
              <p class="text-xs font-semibold uppercase tracking-[0.08em] text-text-tertiary">License</p>
              <p class="mt-1 text-sm font-semibold text-text-primary">Open Source</p>
            </div>
            <div class="rounded-lg border border-gray-700/80 bg-bg-primary/55 px-4 py-3 text-center backdrop-blur-sm md:text-left">
              <p class="text-xs font-semibold uppercase tracking-[0.08em] text-text-tertiary">Security</p>
              <p class="mt-1 text-sm font-semibold text-text-primary">Public Verification</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <section class="bg-bg-secondary px-4 py-20">
    <div class="mx-auto max-w-6xl">
      <h2 class="text-balance text-center font-heading text-3xl font-bold text-text-primary md:text-4xl">
        Why teams choose Moaiy
      </h2>
      <div class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-3">
        <article class="rounded-xl border border-gray-800 bg-bg-primary/45 p-6">
          <h3 class="font-heading text-xl font-semibold text-text-primary">Simple workflow</h3>
          <p class="mt-3 text-sm leading-relaxed text-text-secondary">
            Encrypt, decrypt, and manage keys with clear steps instead of long, fragile command chains.
          </p>
        </article>
        <article class="rounded-xl border border-gray-800 bg-bg-primary/45 p-6">
          <h3 class="font-heading text-xl font-semibold text-text-primary">Security transparency</h3>
          <p class="mt-3 text-sm leading-relaxed text-text-secondary">
            Source code, release artifacts, and security policy are public and easy to inspect.
          </p>
        </article>
        <article class="rounded-xl border border-gray-800 bg-bg-primary/45 p-6">
          <h3 class="font-heading text-xl font-semibold text-text-primary">Practical release path</h3>
          <p class="mt-3 text-sm leading-relaxed text-text-secondary">
            Current focus is macOS, with roadmap and release notes clearly separated from shipped features.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="bg-bg-primary px-4 py-20">
    <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.1fr_1fr] lg:items-start">
      <div>
        <h2 class="text-balance font-heading text-3xl font-bold text-text-primary md:text-4xl">
          Start in three steps
        </h2>
        <ol class="mt-6 space-y-4">
          <li class="rounded-lg border border-gray-800 bg-bg-secondary/65 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">1. Download</p>
            <p class="mt-1 text-sm text-text-secondary">Get the latest build from official GitHub Releases.</p>
          </li>
          <li class="rounded-lg border border-gray-800 bg-bg-secondary/65 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">2. Verify</p>
            <p class="mt-1 text-sm text-text-secondary">Check checksums and signatures before installation.</p>
          </li>
          <li class="rounded-lg border border-gray-800 bg-bg-secondary/65 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">3. Encrypt</p>
            <p class="mt-1 text-sm text-text-secondary">Follow docs for key generation and file encryption workflows.</p>
          </li>
        </ol>
      </div>
      <div class="rounded-xl border border-gray-800 bg-bg-secondary/70 p-6">
        <h3 class="font-heading text-2xl font-semibold text-text-primary">Useful links</h3>
        <div class="mt-5 flex flex-col gap-3">
          <a
            href="/download/"
            data-analytics-event="download_click"
            class="inline-flex items-center justify-between rounded-lg border border-gray-700 bg-bg-primary/55 px-4 py-3 text-sm font-semibold text-text-primary transition-colors hover:border-accent-primary/50 hover:text-accent-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-primary"
          >
            Download Center
            <span aria-hidden="true">→</span>
          </a>
          <a
            href="/security/"
            class="inline-flex items-center justify-between rounded-lg border border-gray-700 bg-bg-primary/55 px-4 py-3 text-sm font-semibold text-text-primary transition-colors hover:border-accent-primary/50 hover:text-accent-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-primary"
          >
            Security Model
            <span aria-hidden="true">→</span>
          </a>
          <a
            href="/docs/"
            class="inline-flex items-center justify-between rounded-lg border border-gray-700 bg-bg-primary/55 px-4 py-3 text-sm font-semibold text-text-primary transition-colors hover:border-accent-primary/50 hover:text-accent-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-primary/70 focus-visible:ring-offset-2 focus-visible:ring-offset-bg-primary"
          >
            Task Docs
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-muted {
    color: var(--hero-tagline-color, rgba(249, 250, 251, 0.95));
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
    transition: color 220ms ease;
  }
</style>
