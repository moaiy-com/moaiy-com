---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.releaseNotes;
const releaseUrl = 'https://github.com/moaiy-com/moaiy/releases';
---

<BaseLayout {...seo}>
  <main class="min-h-screen bg-bg-primary px-4 py-20">
    <div class="mx-auto max-w-5xl">
      <header class="mx-auto mb-14 max-w-3xl text-center">
        <h1 class="text-balance font-heading text-4xl font-bold text-text-primary md:text-5xl">Release notes</h1>
        <p class="mt-4 text-lg leading-relaxed text-text-secondary">
          Product and documentation milestones. For binaries, use official GitHub Releases.
        </p>
      </header>

      <section class="rounded-xl border border-gray-800 bg-bg-secondary/70 p-7 md:p-8">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Recent milestones</h2>
        <div class="mt-6 space-y-5">
          <article class="border-l-2 border-accent-primary pl-4">
            <h3 class="font-heading text-xl text-text-primary">March 31, 2026 · SEO baseline</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-secondary">
              Added structured metadata, sitemap coverage, task-focused docs, and verification resources.
            </p>
          </article>
          <article class="border-l-2 border-accent-primary pl-4">
            <h3 class="font-heading text-xl text-text-primary">March 30, 2026 · Security and docs refinement</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-secondary">
              Clarified security messaging and removed ambiguous "coming soon" claims.
            </p>
          </article>
          <article class="border-l-2 border-accent-primary pl-4">
            <h3 class="font-heading text-xl text-text-primary">March 28, 2026 · Site architecture update</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-secondary">
              Standardized route structure and improved internal linking.
            </p>
          </article>
        </div>
      </section>

      <section class="mt-12 rounded-xl border border-gray-800 bg-bg-secondary/65 p-7 md:p-8">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Official release artifacts</h2>
        <p class="mt-3 text-sm leading-relaxed text-text-secondary">
          Binary availability depends on the latest published artifacts in GitHub Releases.
        </p>
        <a
          href={releaseUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-analytics-event="download_click"
          class="mt-5 inline-flex items-center rounded-lg bg-accent-primary px-5 py-3 text-sm font-semibold text-bg-primary transition-colors hover:bg-accent-secondary"
        >
          View GitHub Releases
        </a>
      </section>

      <section class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-3">
        <a href="/download/" class="rounded-lg border border-gray-800 bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary">
          <h2 class="font-heading text-lg text-text-primary">Download</h2>
          <p class="mt-2 text-sm text-text-secondary">Install from official channels.</p>
        </a>
        <a href="/verification/" class="rounded-lg border border-gray-800 bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary">
          <h2 class="font-heading text-lg text-text-primary">Verification</h2>
          <p class="mt-2 text-sm text-text-secondary">Checksum and signature checks.</p>
        </a>
        <a href="/roadmap/" class="rounded-lg border border-gray-800 bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary">
          <h2 class="font-heading text-lg text-text-primary">Roadmap</h2>
          <p class="mt-2 text-sm text-text-secondary">Upcoming platform scope.</p>
        </a>
      </section>
    </div>
  </main>
</BaseLayout>
