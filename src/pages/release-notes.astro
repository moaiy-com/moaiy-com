---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.releaseNotes;
const releaseUrl = 'https://github.com/moaiy-com/moaiy/releases';
---

<BaseLayout {...seo}>
  <main class="min-h-screen bg-bg-primary py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <header class="text-center mb-14">
        <h1 class="font-heading text-5xl md:text-6xl font-bold text-text-primary mb-4">Release notes</h1>
        <p class="font-body text-xl text-text-secondary">
          Version history and documentation milestones. For binary artifacts, use official GitHub Releases.
        </p>
      </header>

      <section class="mb-12 bg-bg-secondary rounded-xl p-8 border border-gray-800">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-6">Recent milestones</h2>
        <div class="space-y-6">
          <article class="border-l-4 border-accent-primary pl-5">
            <h3 class="font-heading text-xl text-text-primary mb-1">March 31, 2026 - SEO baseline release</h3>
            <p class="font-body text-text-secondary">
              Added structured metadata, sitemap, robots policy, task-focused documentation, and verification resources.
            </p>
          </article>
          <article class="border-l-4 border-accent-primary pl-5">
            <h3 class="font-heading text-xl text-text-primary mb-1">March 30, 2026 - Security and docs restructuring</h3>
            <p class="font-body text-text-secondary">
              Refined public security messaging and reduced ambiguous "coming soon" claims across core pages.
            </p>
          </article>
          <article class="border-l-4 border-accent-primary pl-5">
            <h3 class="font-heading text-xl text-text-primary mb-1">March 28, 2026 - Site architecture improvements</h3>
            <p class="font-body text-text-secondary">
              Standardized route structure and improved page-level linking for crawlability.
            </p>
          </article>
        </div>
      </section>

      <section class="mb-12 bg-bg-secondary rounded-xl p-8 border border-gray-800">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-4">Official release artifacts</h2>
        <p class="font-body text-text-secondary mb-6">
          Binary availability depends on the latest published release artifacts in GitHub.
        </p>
        <a
          href={releaseUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-analytics-event="download_click"
          class="inline-block px-6 py-3 bg-accent-primary text-white font-semibold rounded-lg hover:bg-accent-secondary transition-colors"
        >
          View GitHub Releases
        </a>
      </section>

      <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/download/" class="bg-bg-secondary rounded-xl p-6 border border-gray-800 hover:border-accent-primary/50 transition-colors">
          <h2 class="font-heading text-lg text-text-primary mb-2">Download</h2>
          <p class="font-body text-sm text-text-secondary">Install from official channels.</p>
        </a>
        <a href="/verification/" class="bg-bg-secondary rounded-xl p-6 border border-gray-800 hover:border-accent-primary/50 transition-colors">
          <h2 class="font-heading text-lg text-text-primary mb-2">Verification</h2>
          <p class="font-body text-sm text-text-secondary">Validate checksum and signature data.</p>
        </a>
        <a href="/roadmap/" class="bg-bg-secondary rounded-xl p-6 border border-gray-800 hover:border-accent-primary/50 transition-colors">
          <h2 class="font-heading text-lg text-text-primary mb-2">Roadmap</h2>
          <p class="font-body text-sm text-text-secondary">Track upcoming platform scope.</p>
        </a>
      </section>
    </div>
  </main>
</BaseLayout>
