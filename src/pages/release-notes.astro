---
import LinkCard from '../components/ui/LinkCard.astro';
import PageHero from '../components/ui/PageHero.astro';
import Panel from '../components/ui/Panel.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.releaseNotes;
const releaseUrl = 'https://github.com/moaiy-com/moaiy/releases';
---

<BaseLayout {...seo}>
  <main class="page-shell">
    <div class="page-container-narrow">
      <PageHero
        title="Release notes"
        subtitle="Recent updates to the product website and documentation. Downloads are on GitHub Releases."
      />

      <Panel tone="strong">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Recent milestones</h2>
        <div class="mt-6 space-y-5">
          <article class="border-l-2 border-accent-primary pl-4">
            <h3 class="font-heading text-xl text-text-primary">March 31, 2026 · Search and sharing improvements</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-secondary">
              Improved metadata, sitemap coverage, practical docs, and verification guidance.
            </p>
          </article>
          <article class="border-l-2 border-accent-primary pl-4">
            <h3 class="font-heading text-xl text-text-primary">March 30, 2026 · Clearer security and docs content</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-secondary">
              Updated security wording and removed unclear "coming soon" messaging.
            </p>
          </article>
          <article class="border-l-2 border-accent-primary pl-4">
            <h3 class="font-heading text-xl text-text-primary">March 28, 2026 · Site structure update</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-secondary">
              Simplified page routes and improved internal links.
            </p>
          </article>
        </div>
      </Panel>

      <Panel class="mt-12">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Official downloads</h2>
        <p class="mt-3 text-sm leading-relaxed text-text-secondary">
          The latest install files are published on GitHub Releases.
        </p>
        <a
          href={releaseUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-analytics-event="download_click"
          class="btn-primary mt-5"
        >
          Open GitHub Releases
        </a>
      </Panel>

      <section class="link-grid">
        <LinkCard href="/download/" title="Download" description="Install from the official download page." />
        <LinkCard href="/verification/" title="Verification" description="How to check file hashes and signatures." />
        <LinkCard href="/roadmap/" title="Roadmap" description="What is planned for upcoming releases." />
      </section>
    </div>
  </main>
</BaseLayout>
