---
import LinkCard from '../components/ui/LinkCard.astro';
import PageHero from '../components/ui/PageHero.astro';
import Panel from '../components/ui/Panel.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.download;
const releaseUrl = 'https://github.com/moaiy-com/moaiy/releases';
---

<BaseLayout {...seo}>
  <main class="page-shell">
    <div class="page-container">
      <PageHero
        title="Download Moaiy for macOS"
        subtitle="Use the official release page, then verify the file before installing."
      />

      <Panel tone="strong">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Official download page</h2>
        <p class="mt-3 max-w-3xl text-sm leading-relaxed text-text-secondary">
          Moaiy is distributed through GitHub Releases. Always check release notes and checksums before installing.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={releaseUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-analytics-event="download_click"
            class="btn-primary"
          >
            Open GitHub Releases
          </a>
          <a href="/verification/" class="btn-secondary">
            Check Verification Guide
          </a>
        </div>
      </Panel>

      <Panel class="mt-12">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Current availability</h2>
        <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2">
          <div class="rounded-lg border border-line-subtle bg-bg-primary/45 p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">macOS</p>
            <p class="mt-1 text-sm text-text-secondary">Available now from GitHub Releases.</p>
          </div>
          <div class="rounded-lg border border-line-subtle bg-bg-primary/45 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">Windows / Linux</p>
            <p class="mt-1 text-sm text-text-secondary">Planned. Follow progress in Roadmap and Release Notes.</p>
          </div>
          <div class="rounded-lg border border-line-subtle bg-bg-primary/45 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">iOS / Android</p>
            <p class="mt-1 text-sm text-text-secondary">Planned, not available yet.</p>
          </div>
          <div class="rounded-lg border border-line-subtle bg-bg-primary/45 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">Web / API</p>
            <p class="mt-1 text-sm text-text-secondary">Planned, not publicly available yet.</p>
          </div>
        </div>
      </Panel>

      <Panel class="mt-12">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Build from source (optional)</h2>
        <div class="code-block">
          <div>git clone https://github.com/moaiy-com/moaiy.git</div>
          <div>cd moaiy</div>
          <div>open Moaiy/Moaiy.xcodeproj</div>
          <div>xcodebuild -project Moaiy/Moaiy.xcodeproj -scheme Moaiy -destination 'platform=macOS' build</div>
        </div>
      </Panel>

      <section class="link-grid">
        <LinkCard href="/verification/" title="Verification" description="Checklist to verify files before install." />
        <LinkCard href="/release-notes/" title="Release Notes" description="What changed in recent updates." />
        <LinkCard href="/roadmap/" title="Roadmap" description="What is available now and what comes next." />
      </section>
    </div>
  </main>
</BaseLayout>
