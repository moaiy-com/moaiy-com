---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.download;
const releaseUrl = 'https://github.com/moaiy-com/moaiy/releases';
---

<BaseLayout {...seo}>
  <main class="min-h-screen bg-bg-primary px-4 py-20">
    <div class="mx-auto max-w-6xl">
      <header class="mx-auto mb-14 max-w-3xl text-center">
        <h1 class="text-balance font-heading text-4xl font-bold text-text-primary md:text-5xl">
          Download from official channels
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-text-secondary">
          Current public release path focuses on macOS. Verify integrity before installation.
        </p>
      </header>

      <section class="rounded-xl border border-gray-800 bg-bg-secondary/70 p-7 md:p-8">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Primary release source</h2>
        <p class="mt-3 max-w-3xl text-sm leading-relaxed text-text-secondary">
          Moaiy artifacts are distributed through GitHub Releases. Treat release notes and checksums as part of install.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={releaseUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-analytics-event="download_click"
            class="inline-flex items-center rounded-lg bg-accent-primary px-5 py-3 text-sm font-semibold text-bg-primary transition-colors hover:bg-accent-secondary"
          >
            Open Releases
          </a>
          <a href="/verification/" class="inline-flex items-center rounded-lg border border-gray-600 px-5 py-3 text-sm font-semibold text-text-primary transition-colors hover:border-accent-primary/60 hover:text-accent-primary">
            Verify Checksums
          </a>
        </div>
      </section>

      <section class="mt-12 rounded-xl border border-gray-800 bg-bg-secondary/65 p-7 md:p-8">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Current availability</h2>
        <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2">
          <div class="rounded-lg border border-gray-700 bg-bg-primary/45 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">macOS</p>
            <p class="mt-1 text-sm text-text-secondary">Published release path available via GitHub Releases.</p>
          </div>
          <div class="rounded-lg border border-gray-700 bg-bg-primary/45 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">Windows / Linux</p>
            <p class="mt-1 text-sm text-text-secondary">Planned and tracked in roadmap and release notes.</p>
          </div>
          <div class="rounded-lg border border-gray-700 bg-bg-primary/45 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">iOS / Android</p>
            <p class="mt-1 text-sm text-text-secondary">Planned, not currently published.</p>
          </div>
          <div class="rounded-lg border border-gray-700 bg-bg-primary/45 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">Web / API</p>
            <p class="mt-1 text-sm text-text-secondary">Planned, not publicly deployed.</p>
          </div>
        </div>
      </section>

      <section class="mt-12 rounded-xl border border-gray-800 bg-bg-secondary/65 p-7 md:p-8">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Build from source (optional)</h2>
        <div class="mt-5 space-y-2 rounded-lg bg-bg-tertiary p-4 font-code text-sm text-text-secondary">
          <div>git clone https://github.com/moaiy-com/moaiy.git</div>
          <div>cd moaiy</div>
          <div>open Moaiy/Moaiy.xcodeproj</div>
          <div>xcodebuild -project Moaiy/Moaiy.xcodeproj -scheme Moaiy -destination 'platform=macOS' build</div>
        </div>
      </section>

      <section class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-3">
        <a href="/verification/" class="rounded-lg border border-gray-800 bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary">
          <h2 class="font-heading text-lg text-text-primary">Verification</h2>
          <p class="mt-2 text-sm text-text-secondary">Integrity checklist before install.</p>
        </a>
        <a href="/release-notes/" class="rounded-lg border border-gray-800 bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary">
          <h2 class="font-heading text-lg text-text-primary">Release Notes</h2>
          <p class="mt-2 text-sm text-text-secondary">Published milestones and version changes.</p>
        </a>
        <a href="/roadmap/" class="rounded-lg border border-gray-800 bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary">
          <h2 class="font-heading text-lg text-text-primary">Roadmap</h2>
          <p class="mt-2 text-sm text-text-secondary">Planned platform scope and progress.</p>
        </a>
      </section>
    </div>
  </main>
</BaseLayout>
