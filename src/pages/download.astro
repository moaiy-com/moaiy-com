---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Download - Moaiy" description="Download the latest Moaiy macOS release and verify checksums.">
  <main class="min-h-screen bg-bg-primary py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="font-heading text-5xl md:text-6xl font-bold text-text-primary mb-4">
          Download Moaiy
        </h1>
        <p class="font-body text-xl text-text-secondary">
          Official downloads for the current macOS release
        </p>
      </div>

      <section class="mb-12 bg-bg-secondary rounded-xl p-8 border border-gray-800">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
          <div>
            <h2 class="font-heading text-3xl font-bold text-text-primary mb-3">macOS</h2>
            <p class="font-body text-text-secondary mb-2">Current supported platform: macOS 14.0+</p>
            <p class="font-body text-text-tertiary text-sm">Download DMG from GitHub Releases and verify checksum before first run.</p>
          </div>
          <a
            href="https://github.com/moaiy-com/moaiy/releases"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block px-8 py-4 bg-accent-primary text-white font-semibold rounded-lg hover:bg-accent-secondary transition-colors text-center"
          >
            Open Releases
          </a>
        </div>
      </section>

      <section class="mb-12 bg-bg-secondary rounded-xl p-8 border border-gray-800">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-6">Verify Integrity</h2>
        <p class="font-body text-text-secondary mb-4">
          Release notes include SHA-256 checksums. Compare your downloaded DMG hash with the release checksum.
        </p>
        <div class="bg-bg-tertiary rounded-lg p-5 font-code text-sm text-text-secondary overflow-x-auto">
          <div>shasum -a 256 Moaiy-vX.Y.Z.dmg</div>
        </div>
      </section>

      <section class="mb-12 bg-bg-secondary rounded-xl p-8 border border-gray-800">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-6">Build From Source</h2>
        <p class="font-body text-text-secondary mb-4">
          Prefer building locally? Use Xcode or `xcodebuild`:
        </p>
        <div class="bg-bg-tertiary rounded-lg p-5 font-code text-sm text-text-secondary overflow-x-auto">
          <div>git clone https://github.com/moaiy-com/moaiy.git</div>
          <div>cd moaiy</div>
          <div>open Moaiy/Moaiy.xcodeproj</div>
          <div class="mt-2">xcodebuild -project Moaiy/Moaiy.xcodeproj -scheme Moaiy -destination 'platform=macOS' build</div>
        </div>
      </section>

      <section class="bg-gradient-to-r from-bg-secondary to-bg-tertiary rounded-xl p-8 border border-gray-800">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-6">Roadmap Platforms</h2>
        <p class="font-body text-text-secondary mb-4">
          Windows, Linux, iOS, Android, and Web are not currently released. Future availability will be announced in
          official release notes.
        </p>
        <a
          href="https://github.com/moaiy-com/moaiy"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-6 py-3 border-2 border-accent-primary text-accent-primary font-semibold rounded-lg hover:bg-accent-primary hover:text-white transition-colors"
        >
          Track Project Progress
        </a>
      </section>
    </div>
  </main>
</BaseLayout>
