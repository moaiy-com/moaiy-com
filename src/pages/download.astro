---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.download;
const releaseUrl = 'https://github.com/moaiy-com/moaiy/releases';
---

<BaseLayout {...seo}>
  <main class="min-h-screen bg-bg-primary py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <header class="text-center mb-16">
        <h1 class="font-heading text-5xl md:text-6xl font-bold text-text-primary mb-4">
          Download Moaiy from official channels
        </h1>
        <p class="font-body text-xl text-text-secondary max-w-3xl mx-auto">
          Official downloads currently focus on macOS. Always verify integrity before installation.
        </p>
      </header>

      <section class="mb-12 bg-gradient-to-r from-bg-secondary to-bg-tertiary rounded-xl p-8 border border-gray-800">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-4">Primary release source</h2>
        <p class="font-body text-text-secondary mb-6">
          Moaiy publishes release artifacts through GitHub Releases. Always validate checksums and signatures before use.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href={releaseUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-analytics-event="download_click"
            class="inline-block px-8 py-4 bg-accent-primary text-white font-semibold rounded-lg hover:bg-accent-secondary transition-colors"
          >
            Open GitHub Releases
          </a>
          <a
            href="/verification/"
            class="inline-block px-8 py-4 border-2 border-accent-primary text-accent-primary font-semibold rounded-lg hover:bg-accent-primary hover:text-white transition-colors"
          >
            Verify Checksums
          </a>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-6">Platform status matrix</h2>
        <div class="bg-bg-secondary rounded-xl p-8 border border-gray-800 overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="border-b border-gray-700">
                <th class="font-heading text-text-primary py-3 px-4">Platform</th>
                <th class="font-heading text-text-primary py-3 px-4">Current status</th>
                <th class="font-heading text-text-primary py-3 px-4">Distribution path</th>
              </tr>
            </thead>
            <tbody class="font-body text-text-secondary text-sm">
              <tr class="border-b border-gray-800">
                <td class="py-3 px-4">macOS</td>
                <td class="py-3 px-4">Published release path available</td>
                <td class="py-3 px-4">GitHub Releases</td>
              </tr>
              <tr class="border-b border-gray-800">
                <td class="py-3 px-4">Windows</td>
                <td class="py-3 px-4">Planned / release-dependent</td>
                <td class="py-3 px-4">Roadmap + release notes</td>
              </tr>
              <tr class="border-b border-gray-800">
                <td class="py-3 px-4">Linux</td>
                <td class="py-3 px-4">Planned / release-dependent</td>
                <td class="py-3 px-4">Roadmap + release notes</td>
              </tr>
              <tr class="border-b border-gray-800">
                <td class="py-3 px-4">iOS / Android</td>
                <td class="py-3 px-4">Planned, not published</td>
                <td class="py-3 px-4">Roadmap</td>
              </tr>
              <tr>
                <td class="py-3 px-4">Web/API</td>
                <td class="py-3 px-4">Planned, not publicly deployed</td>
                <td class="py-3 px-4">Roadmap</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="mb-12 bg-bg-secondary rounded-xl p-8 border border-gray-800">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-6">Build from source (optional)</h2>
        <p class="font-body text-text-secondary mb-4">Prefer local builds? Use the official repository and Xcode workflow:</p>
        <div class="bg-bg-tertiary rounded-lg p-5 font-code text-sm text-text-secondary overflow-x-auto space-y-2">
          <div>git clone https://github.com/moaiy-com/moaiy.git</div>
          <div>cd moaiy</div>
          <div>open Moaiy/Moaiy.xcodeproj</div>
          <div>xcodebuild -project Moaiy/Moaiy.xcodeproj -scheme Moaiy -destination 'platform=macOS' build</div>
        </div>
      </section>

      <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/roadmap/" class="bg-bg-secondary rounded-xl p-6 border border-gray-800 hover:border-accent-primary/50 transition-colors">
          <h3 class="font-heading text-lg text-text-primary mb-2">Roadmap</h3>
          <p class="font-body text-sm text-text-secondary">Track upcoming platform and product milestones.</p>
        </a>
        <a href="/release-notes/" class="bg-bg-secondary rounded-xl p-6 border border-gray-800 hover:border-accent-primary/50 transition-colors">
          <h3 class="font-heading text-lg text-text-primary mb-2">Release notes</h3>
          <p class="font-body text-sm text-text-secondary">Review version changes and published milestones.</p>
        </a>
        <a href="/verification/" class="bg-bg-secondary rounded-xl p-6 border border-gray-800 hover:border-accent-primary/50 transition-colors">
          <h3 class="font-heading text-lg text-text-primary mb-2">Verification guide</h3>
          <p class="font-body text-sm text-text-secondary">Validate checksums and signatures before installation.</p>
        </a>
      </section>
    </div>
  </main>
</BaseLayout>
