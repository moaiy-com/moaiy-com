---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.features;
---

<BaseLayout {...seo}>
  <main class="min-h-screen bg-bg-primary px-4 py-20">
    <div class="mx-auto max-w-6xl">
      <header class="mx-auto mb-14 max-w-3xl text-center">
        <h1 class="text-balance font-heading text-4xl font-bold text-text-primary md:text-5xl">
          Features for practical encryption work
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-text-secondary">
          Moaiy keeps encryption workflows clear, verifiable, and suitable for daily desktop operations.
        </p>
      </header>

      <section class="grid grid-cols-1 gap-5 md:grid-cols-3">
        <article class="rounded-xl border border-gray-800 bg-bg-secondary/70 p-6">
          <h2 class="font-heading text-xl font-semibold text-text-primary">Local-first commands</h2>
          <p class="mt-3 text-sm leading-relaxed text-text-secondary">
            Encrypt, decrypt, and manage keys without relying on hosted dashboards.
          </p>
        </article>
        <article class="rounded-xl border border-gray-800 bg-bg-secondary/70 p-6">
          <h2 class="font-heading text-xl font-semibold text-text-primary">Open-source trust</h2>
          <p class="mt-3 text-sm leading-relaxed text-text-secondary">
            Core code and release channels stay public for inspection and independent review.
          </p>
        </article>
        <article class="rounded-xl border border-gray-800 bg-bg-secondary/70 p-6">
          <h2 class="font-heading text-xl font-semibold text-text-primary">Operational safety</h2>
          <p class="mt-3 text-sm leading-relaxed text-text-secondary">
            Verification docs and disclosure policies are first-class parts of the project.
          </p>
        </article>
      </section>

      <section class="mt-12 rounded-xl border border-gray-800 bg-bg-secondary/65 p-7 md:p-8">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Workflow at a glance</h2>
        <ol class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2">
          <li class="rounded-lg border border-gray-700 bg-bg-primary/50 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">Step 1</p>
            <p class="mt-1 text-sm text-text-secondary">Download from official GitHub Releases.</p>
          </li>
          <li class="rounded-lg border border-gray-700 bg-bg-primary/50 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">Step 2</p>
            <p class="mt-1 text-sm text-text-secondary">Verify checksums and signatures before install.</p>
          </li>
          <li class="rounded-lg border border-gray-700 bg-bg-primary/50 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">Step 3</p>
            <p class="mt-1 text-sm text-text-secondary">Generate and manage keys locally.</p>
          </li>
          <li class="rounded-lg border border-gray-700 bg-bg-primary/50 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.08em] text-accent-primary">Step 4</p>
            <p class="mt-1 text-sm text-text-secondary">Run encryption tasks with documented commands.</p>
          </li>
        </ol>
      </section>

      <section class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-3">
        <a href="/docs/" class="rounded-lg border border-gray-800 bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary">
          <h2 class="font-heading text-lg text-text-primary">Read Docs</h2>
          <p class="mt-2 text-sm text-text-secondary">Command workflows and examples.</p>
        </a>
        <a href="/download/" data-analytics-event="download_click" class="rounded-lg border border-gray-800 bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary">
          <h2 class="font-heading text-lg text-text-primary">Get Releases</h2>
          <p class="mt-2 text-sm text-text-secondary">Official artifacts and install path.</p>
        </a>
        <a href="/security/" class="rounded-lg border border-gray-800 bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary">
          <h2 class="font-heading text-lg text-text-primary">Security Model</h2>
          <p class="mt-2 text-sm text-text-secondary">Disclosure policy and evidence status.</p>
        </a>
      </section>
    </div>
  </main>
</BaseLayout>
