---
import BaseLayout from '../layouts/BaseLayout.astro';

const seo = {
  title: 'Terms - Moaiy',
  description: 'Terms for using moaiy.com resources and releases.',
  canonicalPath: '/terms/',
  currentPage: '',
  schema: [
    {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: 'Terms - Moaiy',
      url: 'https://moaiy.com/terms/',
    },
  ],
};
---

<BaseLayout {...seo}>
  <main class="min-h-screen bg-bg-primary px-4 py-20">
    <div class="mx-auto max-w-4xl rounded-xl border border-gray-800 bg-bg-secondary/70 p-7 md:p-8">
      <header>
        <h1 class="font-heading text-4xl font-bold text-text-primary md:text-5xl">Terms</h1>
        <p class="mt-3 text-sm text-text-tertiary">Last updated: 2026-03-31</p>
      </header>

      <div class="mt-8 space-y-6 text-sm leading-relaxed text-text-secondary">
        <section>
          <h2 class="font-heading text-2xl font-semibold text-text-primary">Use of website</h2>
          <p class="mt-2">
            This website provides project information, documentation links, and release navigation.
            Use it lawfully and do not abuse, disrupt, or attack the service.
          </p>
        </section>

        <section>
          <h2 class="font-heading text-2xl font-semibold text-text-primary">Open-source licensing</h2>
          <p class="mt-2">
            The Moaiy application repository is distributed under the MIT License.
            The repository license file is the authoritative source.
          </p>
        </section>

        <section>
          <h2 class="font-heading text-2xl font-semibold text-text-primary">No warranty</h2>
          <p class="mt-2">
            Software and website content are provided "as is" without warranties.
            You are responsible for key safety, backup hygiene, and operational validation.
          </p>
        </section>

        <section>
          <h2 class="font-heading text-2xl font-semibold text-text-primary">Third-party services</h2>
          <p class="mt-2">
            This site may link to third-party platforms such as GitHub.
            Their terms and privacy policies apply when you use those services.
          </p>
        </section>

        <section>
          <h2 class="font-heading text-2xl font-semibold text-text-primary">Contact</h2>
          <p class="mt-2">
            Questions about these terms:
            <a href="mailto:support@moaiy.com" class="text-accent-primary hover:underline">support@moaiy.com</a>
          </p>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>
