---
import LinkCard from '../components/ui/LinkCard.astro';
import PageHero from '../components/ui/PageHero.astro';
import Panel from '../components/ui/Panel.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.openpgpMadeSimple;
---

<BaseLayout {...seo}>
  <main class="page-shell">
    <div class="page-container-compact">
      <PageHero
        centered={false}
        title="OpenPGP made simple with Moaiy"
        subtitle="Understand the key model and run a workflow users can follow."
      />

      <Panel tone="strong">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Core model</h2>
        <ul class="list-compact">
          <li><span class="text-text-primary">Public key</span>: share with senders who encrypt files for you.</li>
          <li><span class="text-text-primary">Private key</span>: keep secret; it decrypts files addressed to you.</li>
          <li><span class="text-text-primary">Passphrase</span>: protects your private key on disk.</li>
        </ul>
      </Panel>

      <Panel class="mt-12">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Workflow example</h2>
        <div class="code-block">
          <div><span class="text-accent-primary">$</span> moaiy key generate</div>
          <div><span class="text-accent-primary">$</span> moaiy key export --output my-public.key</div>
          <div><span class="text-accent-primary">$</span> moaiy encrypt payroll.csv --recipient finance@example.com</div>
          <div><span class="text-accent-primary">$</span> moaiy decrypt payroll.csv.gpg</div>
        </div>
      </Panel>

      <Panel class="mt-12">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Common mistakes</h2>
        <ul class="list-compact">
          <li>Storing private keys in shared folders.</li>
          <li>Skipping checksum checks for new binaries.</li>
          <li>Reusing weak passphrases across systems.</li>
        </ul>
      </Panel>

      <section class="link-grid">
        <LinkCard href="/docs/" title="Task Docs" description="Command references and usage patterns." />
        <LinkCard href="/verification/" title="Verification" description="Trusted installation checklist." />
        <LinkCard href="/gpg-tools-alternative/" title="Alternative View" description="Compare Moaiy and classic GPG UX." />
      </section>
    </div>
  </main>
</BaseLayout>
