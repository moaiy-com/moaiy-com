---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.gpgToolsAlternative;
---

<BaseLayout {...seo}>
  <main class="min-h-screen bg-bg-primary px-4 py-20">
    <div class="mx-auto max-w-5xl">
      <header class="mx-auto mb-14 max-w-3xl text-center">
        <h1 class="text-balance font-heading text-4xl font-bold text-text-primary md:text-5xl">
          Is Moaiy a practical GPG alternative?
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-text-secondary">
          Compare workflow clarity, verification habits, and day-to-day usability.
        </p>
      </header>

      <section class="rounded-xl border border-gray-800 bg-bg-secondary/70 p-7 md:p-8">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Workflow comparison</h2>
        <div class="mt-6 overflow-x-auto">
          <table class="w-full min-w-[620px] text-left text-sm text-text-secondary">
            <thead>
              <tr class="border-b border-gray-700 text-text-primary">
                <th class="py-3 pr-4 font-heading">Dimension</th>
                <th class="px-4 py-3 font-heading">Traditional GPG flow</th>
                <th class="px-4 py-3 font-heading">Moaiy focus</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-800">
                <td class="py-3 pr-4">Onboarding</td>
                <td class="px-4 py-3">Power-user oriented</td>
                <td class="px-4 py-3">Task-first documentation</td>
              </tr>
              <tr class="border-b border-gray-800">
                <td class="py-3 pr-4">Command discovery</td>
                <td class="px-4 py-3">Scattered across legacy docs and flags</td>
                <td class="px-4 py-3">Focused guides for common tasks</td>
              </tr>
              <tr class="border-b border-gray-800">
                <td class="py-3 pr-4">Release trust process</td>
                <td class="px-4 py-3">Varies by distribution source</td>
                <td class="px-4 py-3">Dedicated verification guidance</td>
              </tr>
              <tr>
                <td class="py-3 pr-4">Scope communication</td>
                <td class="px-4 py-3">Spread across many tools</td>
                <td class="px-4 py-3">Published vs planned status is explicit</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="mt-12 rounded-xl border border-gray-800 bg-bg-secondary/65 p-7 md:p-8">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">When Moaiy fits well</h2>
        <ul class="mt-5 space-y-2 text-sm leading-relaxed text-text-secondary">
          <li>You need clearer docs and repeatable command workflows.</li>
          <li>You require explicit verification guidance for onboarding.</li>
          <li>You prefer open-source transparency with lower UX friction.</li>
        </ul>
      </section>

      <section class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-3">
        <a href="/docs/" class="rounded-lg border border-gray-800 bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary">
          <h2 class="font-heading text-lg text-text-primary">Read Docs</h2>
          <p class="mt-2 text-sm text-text-secondary">Command-level workflows.</p>
        </a>
        <a href="/download/" data-analytics-event="download_click" class="rounded-lg border border-gray-800 bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary">
          <h2 class="font-heading text-lg text-text-primary">Try Releases</h2>
          <p class="mt-2 text-sm text-text-secondary">Inspect latest official artifacts.</p>
        </a>
        <a href="/openpgp-made-simple/" class="rounded-lg border border-gray-800 bg-bg-secondary/55 p-5 transition-colors hover:border-accent-primary/50 hover:text-accent-primary">
          <h2 class="font-heading text-lg text-text-primary">OpenPGP Primer</h2>
          <p class="mt-2 text-sm text-text-secondary">Concept-first guide.</p>
        </a>
      </section>
    </div>
  </main>
</BaseLayout>
