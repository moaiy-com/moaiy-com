---
import LinkCard from '../components/ui/LinkCard.astro';
import PageHero from '../components/ui/PageHero.astro';
import Panel from '../components/ui/Panel.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.gpgToolsAlternative;
---

<BaseLayout {...seo}>
  <main class="page-shell">
    <div class="page-container-narrow">
      <PageHero
        title="Is Moaiy a practical GPG alternative?"
        subtitle="Compare workflow clarity, verification habits, and day-to-day usability."
      />

      <Panel tone="strong">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Workflow comparison</h2>
        <div class="mt-6 overflow-x-auto">
          <table class="w-full min-w-[620px] text-left text-sm text-text-secondary">
            <thead>
              <tr class="border-b border-gray-700 text-text-primary">
                <th class="py-3 pr-4 font-heading">Dimension</th>
                <th class="px-4 py-3 font-heading">Traditional GPG flow</th>
                <th class="px-4 py-3 font-heading">Moaiy focus</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-800">
                <td class="py-3 pr-4">Onboarding</td>
                <td class="px-4 py-3">Power-user oriented</td>
                <td class="px-4 py-3">Task-first documentation</td>
              </tr>
              <tr class="border-b border-gray-800">
                <td class="py-3 pr-4">Command discovery</td>
                <td class="px-4 py-3">Scattered across legacy docs and flags</td>
                <td class="px-4 py-3">Focused guides for common tasks</td>
              </tr>
              <tr class="border-b border-gray-800">
                <td class="py-3 pr-4">Release trust process</td>
                <td class="px-4 py-3">Varies by distribution source</td>
                <td class="px-4 py-3">Dedicated verification guidance</td>
              </tr>
              <tr>
                <td class="py-3 pr-4">Scope communication</td>
                <td class="px-4 py-3">Spread across many tools</td>
                <td class="px-4 py-3">Published vs planned status is explicit</td>
              </tr>
            </tbody>
          </table>
        </div>
      </Panel>

      <Panel class="mt-12">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">When Moaiy fits well</h2>
        <ul class="list-compact">
          <li>You need clearer docs and repeatable command workflows.</li>
          <li>You require explicit verification guidance for onboarding.</li>
          <li>You prefer open-source transparency with lower UX friction.</li>
        </ul>
      </Panel>

      <section class="link-grid">
        <LinkCard href="/docs/" title="Read Docs" description="Command-level workflows." />
        <LinkCard href="/download/" analyticsEvent="download_click" title="Try Releases" description="Inspect latest official artifacts." />
        <LinkCard href="/openpgp-made-simple/" title="OpenPGP Primer" description="Concept-first guide." />
      </section>
    </div>
  </main>
</BaseLayout>
