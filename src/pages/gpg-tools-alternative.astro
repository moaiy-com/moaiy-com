---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.gpgToolsAlternative;
---

<BaseLayout {...seo}>
  <main class="min-h-screen bg-bg-primary py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <header class="text-center mb-14">
        <h1 class="font-heading text-5xl md:text-6xl font-bold text-text-primary mb-4">
          Is Moaiy a practical GPG tools alternative?
        </h1>
        <p class="font-body text-xl text-text-secondary">
          Compare workflow design, documentation quality, and operational verification habits.
        </p>
      </header>

      <section class="mb-12 bg-bg-secondary rounded-xl p-8 border border-gray-800 overflow-x-auto">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-6">Workflow comparison</h2>
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-gray-700">
              <th class="font-heading text-text-primary py-3 px-4">Dimension</th>
              <th class="font-heading text-text-primary py-3 px-4">Traditional GPG flow</th>
              <th class="font-heading text-text-primary py-3 px-4">Moaiy focus</th>
            </tr>
          </thead>
          <tbody class="font-body text-text-secondary text-sm">
            <tr class="border-b border-gray-800">
              <td class="py-3 px-4">Onboarding</td>
              <td class="py-3 px-4">Power-user oriented</td>
              <td class="py-3 px-4">Task-first documentation</td>
            </tr>
            <tr class="border-b border-gray-800">
              <td class="py-3 px-4">Command discoverability</td>
              <td class="py-3 px-4">Depends on legacy docs and flags</td>
              <td class="py-3 px-4">Focused docs for common tasks</td>
            </tr>
            <tr class="border-b border-gray-800">
              <td class="py-3 px-4">Release trust process</td>
              <td class="py-3 px-4">Varies by distribution channel</td>
              <td class="py-3 px-4">Dedicated verification page and release references</td>
            </tr>
            <tr>
              <td class="py-3 px-4">Scope communication</td>
              <td class="py-3 px-4">Feature spread across many tools</td>
              <td class="py-3 px-4">Roadmap separates published vs planned items</td>
            </tr>
          </tbody>
        </table>
      </section>

      <section class="mb-12 bg-bg-secondary rounded-xl p-8 border border-gray-800">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-4">When Moaiy is a strong fit</h2>
        <ul class="font-body text-text-secondary space-y-2 leading-relaxed">
          <li>Your team wants clearer docs and repeatable command workflows.</li>
          <li>You require explicit release verification guidance for onboarding.</li>
          <li>You prefer open-source transparency with fewer UX hurdles.</li>
        </ul>
      </section>

      <section class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/docs/" class="bg-bg-secondary rounded-xl p-6 border border-gray-800 hover:border-accent-primary/50 transition-colors">
          <h2 class="font-heading text-lg text-text-primary mb-2">Read docs</h2>
          <p class="font-body text-sm text-text-secondary">See command-level workflows.</p>
        </a>
        <a href="/download/" data-analytics-event="download_click" class="bg-bg-secondary rounded-xl p-6 border border-gray-800 hover:border-accent-primary/50 transition-colors">
          <h2 class="font-heading text-lg text-text-primary mb-2">Try release channel</h2>
          <p class="font-body text-sm text-text-secondary">Inspect latest official artifacts.</p>
        </a>
        <a href="/openpgp-made-simple/" class="bg-bg-secondary rounded-xl p-6 border border-gray-800 hover:border-accent-primary/50 transition-colors">
          <h2 class="font-heading text-lg text-text-primary mb-2">OpenPGP primer</h2>
          <p class="font-body text-sm text-text-secondary">Start with concept-first guidance.</p>
        </a>
      </section>
    </div>
  </main>
</BaseLayout>
