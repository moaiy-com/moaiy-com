---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Security - Moaiy">
  <main class="min-h-screen bg-bg-primary py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="font-heading text-5xl md:text-6xl font-bold text-text-primary mb-4">
          Security
        </h1>
        <p class="font-body text-xl text-text-secondary">
          Built with security as the foundation, not an afterthought
        </p>
      </div>
      
      <!-- Core Security Principles -->
      <section class="mb-20">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-8 text-center">
          🔐 Core Security Principles
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-bg-secondary rounded-xl p-8 border border-gray-800 hover:border-accent-primary/50 transition-all">
            <div class="text-5xl mb-4">🛡️</div>
            <h3 class="font-heading text-xl font-semibold text-text-primary mb-3">
              Zero-Knowledge
            </h3>
            <p class="font-body text-text-secondary">
              Your data never leaves your device unencrypted. We can't access your data even if we wanted to.
            </p>
          </div>
          
          <div class="bg-bg-secondary rounded-xl p-8 border border-gray-800 hover:border-accent-primary/50 transition-all">
            <div class="text-5xl mb-4">🔓</div>
            <h3 class="font-heading text-xl font-semibold text-text-primary mb-3">
              Open Source
            </h3>
            <p class="font-body text-text-secondary">
              100% open source code. Every line can be audited by anyone. No hidden backdoors.
            </p>
          </div>
          
          <div class="bg-bg-secondary rounded-xl p-8 border border-gray-800 hover:border-accent-primary/50 transition-all">
            <div class="text-5xl mb-4">🔑</div>
            <h3 class="font-heading text-xl font-semibold text-text-primary mb-3">
              Client-Side Encryption
            </h3>
            <p class="font-body text-text-secondary">
              All encryption happens locally on your device. No server-side processing of plaintext.
            </p>
          </div>
        </div>
      </section>
      
      <!-- Encryption Technology -->
      <section class="mb-20">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-8 text-center">
          🔬 Encryption Technology
        </h2>
        
        <div class="bg-bg-secondary rounded-xl p-8 border border-gray-800">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            <!-- Left Column -->
            <div>
              <h3 class="font-heading text-2xl font-semibold text-text-primary mb-6">
                Symmetric Encryption
              </h3>
              <div class="space-y-4">
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-accent-primary text-xl">🔒</span>
                    <h4 class="font-heading text-lg font-semibold text-text-primary">Algorithm</h4>
                  </div>
                  <p class="font-body text-text-secondary">
                    AES-256-GCM (Advanced Encryption Standard with Galois/Counter Mode)
                  </p>
                </div>
                
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-accent-primary text-xl">🔢</span>
                    <h4 class="font-heading text-lg font-semibold text-text-primary">Key Size</h4>
                  </div>
                  <p class="font-body text-text-secondary">
                    256-bit keys (military-grade security)
                  </p>
                </div>
                
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-accent-primary text-xl">✅</span>
                    <h4 class="font-heading text-lg font-semibold text-text-primary">Authenticated</h4>
                  </div>
                  <p class="font-body text-text-secondary">
                    GCM mode provides both encryption and authentication
                  </p>
                </div>
              </div>
            </div>
            
            <!-- Right Column -->
            <div>
              <h3 class="font-heading text-2xl font-semibold text-text-primary mb-6">
                Asymmetric Encryption
              </h3>
              <div class="space-y-4">
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-accent-primary text-xl">🔑</span>
                    <h4 class="font-heading text-lg font-semibold text-text-primary">Algorithm</h4>
                  </div>
                  <p class="font-body text-text-secondary">
                    RSA-4096 or Curve25519 (your choice)
                  </p>
                </div>
                
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-accent-primary text-xl">📜</span>
                    <h4 class="font-heading text-lg font-semibold text-text-primary">Standard</h4>
                  </div>
                  <p class="font-body text-text-secondary">
                    OpenPGP (RFC 4880) for maximum compatibility
                  </p>
                </div>
                
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-accent-primary text-xl">🔄</span>
                    <h4 class="font-heading text-lg font-semibold text-text-primary">Perfect Forward Secrecy</h4>
                  </div>
                  <p class="font-body text-text-secondary">
                    Ephemeral keys for each session
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      
      <!-- Security Architecture -->
      <section class="mb-20">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-8 text-center">
          🏗️ Security Architecture
        </h2>
        
        <div class="bg-bg-secondary rounded-xl p-8 border border-gray-800">
          <div class="space-y-8">
            <!-- Layer 1 -->
            <div>
              <h3 class="font-heading text-xl font-semibold text-accent-primary mb-4">
                Layer 1: Application Security
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <p class="font-body text-text-secondary">
                    <span class="text-accent-primary">✓</span> Memory-safe Rust language
                  </p>
                </div>
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <p class="font-body text-text-secondary">
                    <span class="text-accent-primary">✓</span> No buffer overflows
                  </p>
                </div>
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <p class="font-body text-text-secondary">
                    <span class="text-accent-primary">✓</span> No data races
                  </p>
                </div>
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <p class="font-body text-text-secondary">
                    <span class="text-accent-primary">✓</span> Type-safe cryptography
                  </p>
                </div>
              </div>
            </div>
            
            <!-- Layer 2 -->
            <div>
              <h3 class="font-heading text-xl font-semibold text-accent-primary mb-4">
                Layer 2: Data Security
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <p class="font-body text-text-secondary">
                    <span class="text-accent-primary">✓</span> Client-side encryption only
                  </p>
                </div>
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <p class="font-body text-text-secondary">
                    <span class="text-accent-primary">✓</span> No plaintext transmission
                  </p>
                </div>
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <p class="font-body text-text-secondary">
                    <span class="text-accent-primary">✓</span> Secure key storage
                  </p>
                </div>
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <p class="font-body text-text-secondary">
                    <span class="text-accent-primary">✓</span> Encrypted local cache
                  </p>
                </div>
              </div>
            </div>
            
            <!-- Layer 3 -->
            <div>
              <h3 class="font-heading text-xl font-semibold text-accent-primary mb-4">
                Layer 3: Network Security
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <p class="font-body text-text-secondary">
                    <span class="text-accent-primary">✓</span> TLS 1.3 for all connections
                  </p>
                </div>
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <p class="font-body text-text-secondary">
                    <span class="text-accent-primary">✓</span> Certificate pinning
                  </p>
                </div>
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <p class="font-body text-text-secondary">
                    <span class="text-accent-primary">✓</span> No metadata leakage
                  </p>
                </div>
                <div class="bg-bg-tertiary rounded-lg p-4">
                  <p class="font-body text-text-secondary">
                    <span class="text-accent-primary">✓</span> Offline-first design
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      
      <!-- Security Audit -->
      <section class="mb-20">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-8 text-center">
          🔍 Security Audits
        </h2>
        
        <div class="bg-gradient-to-r from-bg-secondary to-bg-tertiary rounded-xl p-8 border border-gray-800">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Completed Audits -->
            <div>
              <h3 class="font-heading text-xl font-semibold text-text-primary mb-4">
                Completed Audits
              </h3>
              <div class="space-y-4">
                <div class="bg-bg-primary rounded-lg p-4 border border-gray-700">
                  <div class="flex items-start justify-between mb-2">
                    <h4 class="font-heading text-lg font-semibold text-text-primary">
                      Internal Security Review
                    </h4>
                    <span class="text-accent-primary text-sm">✓ Complete</span>
                  </div>
                  <p class="font-body text-text-secondary text-sm mb-2">
                    Conducted by core team • March 2026
                  </p>
                  <span class="font-body text-text-tertiary text-sm">
                    Report publication in progress
                  </span>
                </div>
                
                <div class="bg-bg-primary rounded-lg p-4 border border-gray-700">
                  <div class="flex items-start justify-between mb-2">
                    <h4 class="font-heading text-lg font-semibold text-text-primary">
                      Cryptographic Implementation Review
                    </h4>
                    <span class="text-accent-primary text-sm">✓ Complete</span>
                  </div>
                  <p class="font-body text-text-secondary text-sm mb-2">
                    Conducted by core team • March 2026
                  </p>
                  <span class="font-body text-text-tertiary text-sm">
                    Report publication in progress
                  </span>
                </div>
              </div>
            </div>
            
            <!-- Planned Audits -->
            <div>
              <h3 class="font-heading text-xl font-semibold text-text-primary mb-4">
                Planned Audits
              </h3>
              <div class="space-y-4">
                <div class="bg-bg-primary rounded-lg p-4 border border-gray-700 opacity-75">
                  <div class="flex items-start justify-between mb-2">
                    <h4 class="font-heading text-lg font-semibold text-text-primary">
                      Third-Party Security Audit
                    </h4>
                    <span class="text-text-tertiary text-sm">⏳ Q2 2026</span>
                  </div>
                  <p class="font-body text-text-secondary text-sm">
                    Independent security firm to conduct comprehensive audit
                  </p>
                </div>
                
                <div class="bg-bg-primary rounded-lg p-4 border border-gray-700 opacity-75">
                  <div class="flex items-start justify-between mb-2">
                    <h4 class="font-heading text-lg font-semibold text-text-primary">
                      Formal Verification
                    </h4>
                    <span class="text-text-tertiary text-sm">⏳ Q3 2026</span>
                  </div>
                  <p class="font-body text-text-secondary text-sm">
                    Mathematical proof of cryptographic correctness
                  </p>
                </div>
                
                <div class="bg-bg-primary rounded-lg p-4 border border-gray-700 opacity-75">
                  <div class="flex items-start justify-between mb-2">
                    <h4 class="font-heading text-lg font-semibold text-text-primary">
                      Penetration Testing
                    </h4>
                    <span class="text-text-tertiary text-sm">⏳ Q3 2026</span>
                  </div>
                  <p class="font-body text-text-secondary text-sm">
                    External penetration testing by security researchers
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
      
      <!-- Bug Bounty -->
      <section class="mb-20">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-8 text-center">
          🐛 Bug Bounty Program
        </h2>
        
        <div class="bg-bg-secondary rounded-xl p-8 border border-gray-800">
          <div class="max-w-3xl mx-auto">
            <p class="font-body text-text-secondary text-lg mb-6 text-center">
              We take security seriously. If you discover a vulnerability, we want to hear from you.
            </p>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
              <div class="text-center">
                <div class="text-3xl mb-2">🥇</div>
                <h4 class="font-heading text-lg font-semibold text-text-primary mb-1">Critical</h4>
                <p class="font-body text-accent-primary font-semibold">$5,000+</p>
              </div>
              
              <div class="text-center">
                <div class="text-3xl mb-2">🥈</div>
                <h4 class="font-heading text-lg font-semibold text-text-primary mb-1">High</h4>
                <p class="font-body text-accent-primary font-semibold">$2,000+</p>
              </div>
              
              <div class="text-center">
                <div class="text-3xl mb-2">🥉</div>
                <h4 class="font-heading text-lg font-semibold text-text-primary mb-1">Medium</h4>
                <p class="font-body text-accent-primary font-semibold">$500+</p>
              </div>
            </div>
            
            <div class="text-center">
              <a
                href="mailto:security@moaiy.com"
                class="inline-block px-8 py-4 bg-accent-primary text-white font-semibold rounded-lg hover:bg-accent-secondary transition-colors"
              >
                Report a Vulnerability
              </a>
              <p class="font-body text-text-tertiary text-sm mt-3">
                Email: security@moaiy.com • PGP Key: 0xABC123...
              </p>
            </div>
          </div>
        </div>
      </section>
      
      <!-- Security Best Practices -->
      <section>
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-8 text-center">
          ✨ Security Best Practices
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-bg-tertiary rounded-lg p-6">
            <h4 class="font-heading text-lg font-semibold text-text-primary mb-3">
              🔑 Protect Your Keys
            </h4>
            <ul class="font-body text-text-secondary space-y-2 text-sm">
              <li>• Never share your private keys</li>
              <li>• Use strong, unique passwords</li>
              <li>• Enable two-factor authentication</li>
              <li>• Backup your keys securely</li>
            </ul>
          </div>
          
          <div class="bg-bg-tertiary rounded-lg p-6">
            <h4 class="font-heading text-lg font-semibold text-text-primary mb-3">
              🔄 Keep Updated
            </h4>
            <ul class="font-body text-text-secondary space-y-2 text-sm">
              <li>• Always use the latest version</li>
              <li>• Enable automatic updates</li>
              <li>• Review security advisories</li>
              <li>• Update your OS regularly</li>
            </ul>
          </div>
          
          <div class="bg-bg-tertiary rounded-lg p-6">
            <h4 class="font-heading text-lg font-semibold text-text-primary mb-3">
              🔍 Verify Recipients
            </h4>
            <ul class="font-body text-text-secondary space-y-2 text-sm">
              <li>• Always verify fingerprints</li>
              <li>• Use trusted channels for key exchange</li>
              <li>• Check digital signatures</li>
              <li>• Be cautious of phishing</li>
            </ul>
          </div>
          
          <div class="bg-bg-tertiary rounded-lg p-6">
            <h4 class="font-heading text-lg font-semibold text-text-primary mb-3">
              💻 Secure Your Device
            </h4>
            <ul class="font-body text-text-secondary space-y-2 text-sm">
              <li>• Use device encryption</li>
              <li>• Enable screen lock</li>
              <li>• Use a password manager</li>
              <li>• Avoid public WiFi for sensitive operations</li>
            </ul>
          </div>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
