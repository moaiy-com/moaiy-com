---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.about;
---

<BaseLayout {...seo}>
  <main class="min-h-screen bg-bg-primary py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <header class="text-center mb-16">
        <h1 class="font-heading text-5xl md:text-6xl font-bold text-text-primary mb-4">
          About Moaiy
        </h1>
        <p class="font-body text-xl text-text-secondary">
          Building practical encryption workflows with open-source transparency.
        </p>
      </header>

      <section class="mb-12 bg-bg-secondary rounded-xl p-8 border border-gray-800">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-4">Mission</h2>
        <p class="font-body text-text-secondary text-lg leading-relaxed mb-4">
          Moaiy exists to make robust encryption workflows easier to execute without reducing operational rigor.
        </p>
        <p class="font-body text-text-secondary text-lg leading-relaxed">
          The project emphasizes clear documentation, verifiable release channels, and realistic security claims.
        </p>
      </section>

      <section class="mb-12 bg-bg-secondary rounded-xl p-8 border border-gray-800">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-4">Open-source policy</h2>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="https://github.com/moaiy-com/moaiy"
            target="_blank"
            rel="noopener noreferrer"
            data-analytics-event="github_click"
            class="px-6 py-3 bg-accent-primary text-white font-semibold rounded-lg hover:bg-accent-secondary transition-colors text-center"
          >
            Core Repository
          </a>
          <a
            href="https://github.com/moaiy-com/moaiy/blob/main/LICENSE"
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3 border-2 border-accent-primary text-accent-primary font-semibold rounded-lg hover:bg-accent-primary hover:text-white transition-colors text-center"
          >
            License
          </a>
        </div>
      </section>

      <section class="mb-12 bg-bg-secondary rounded-xl p-8 border border-gray-800">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-4">Project information architecture</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <a href="/security/" class="bg-bg-tertiary rounded-lg p-5 border border-gray-700 hover:border-accent-primary/50 transition-colors">
            <h3 class="font-heading text-lg text-text-primary mb-2">Security policy</h3>
            <p class="font-body text-sm text-text-secondary">Threat model scope, disclosure process, and assurance status.</p>
          </a>
          <a href="/release-notes/" class="bg-bg-tertiary rounded-lg p-5 border border-gray-700 hover:border-accent-primary/50 transition-colors">
            <h3 class="font-heading text-lg text-text-primary mb-2">Release notes</h3>
            <p class="font-body text-sm text-text-secondary">Version timeline and operational updates.</p>
          </a>
          <a href="/verification/" class="bg-bg-tertiary rounded-lg p-5 border border-gray-700 hover:border-accent-primary/50 transition-colors">
            <h3 class="font-heading text-lg text-text-primary mb-2">Verification guide</h3>
            <p class="font-body text-sm text-text-secondary">Checksum and signature validation workflow.</p>
          </a>
          <a href="/roadmap/" class="bg-bg-tertiary rounded-lg p-5 border border-gray-700 hover:border-accent-primary/50 transition-colors">
            <h3 class="font-heading text-lg text-text-primary mb-2">Roadmap</h3>
            <p class="font-body text-sm text-text-secondary">Planned features with explicit status labels.</p>
          </a>
        </div>
      </section>

      <section class="bg-gradient-to-r from-bg-secondary to-bg-tertiary rounded-xl p-8 border border-gray-800">
        <h2 class="font-heading text-3xl font-bold text-text-primary mb-4">Contact</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <h3 class="font-heading text-lg font-semibold text-text-primary mb-2">General</h3>
            <a href="mailto:support@moaiy.com" class="font-body text-accent-primary hover:underline">support@moaiy.com</a>
          </div>
          <div>
            <h3 class="font-heading text-lg font-semibold text-text-primary mb-2">Security</h3>
            <a href="mailto:security@moaiy.com" class="font-body text-accent-primary hover:underline">security@moaiy.com</a>
          </div>
          <div>
            <h3 class="font-heading text-lg font-semibold text-text-primary mb-2">X</h3>
            <a href="https://x.com/moaiycom" target="_blank" rel="noopener noreferrer" class="font-body text-accent-primary hover:underline">@moaiycom</a>
          </div>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
