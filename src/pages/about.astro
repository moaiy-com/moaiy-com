---
import LinkCard from '../components/ui/LinkCard.astro';
import PageHero from '../components/ui/PageHero.astro';
import Panel from '../components/ui/Panel.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { pageSeo } from '../seo/page-config';

const seo = pageSeo.about;
---

<BaseLayout {...seo}>
  <main class="page-shell">
    <div class="page-container-narrow">
      <PageHero
        title="About Moaiy"
        subtitle="Helping people protect files with simple steps and open-source transparency."
      />

      <Panel tone="strong">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Mission</h2>
        <p class="mt-4 text-sm leading-relaxed text-text-secondary">
          Moaiy helps people protect important files without complicated setup. The project focuses on clear guidance,
          public code, and trustworthy downloads from official sources.
        </p>
      </Panel>

      <section class="mt-12">
        <h2 class="text-center font-heading text-2xl font-semibold text-text-primary md:text-3xl">Core principles</h2>
        <div class="mt-6 grid grid-cols-1 gap-5 md:grid-cols-3">
          <Panel as="article" class="p-6 text-center">
            <div class="mx-auto flex h-9 w-9 items-center justify-center rounded-full border border-accent-primary/50 text-sm font-semibold text-accent-primary">1</div>
            <h3 class="mt-3 font-heading text-lg text-text-primary">Simple</h3>
            <p class="mt-2 text-sm text-text-secondary">Readable docs and repeatable command patterns.</p>
          </Panel>
          <Panel as="article" class="p-6 text-center">
            <div class="mx-auto flex h-9 w-9 items-center justify-center rounded-full border border-accent-primary/50 text-sm font-semibold text-accent-primary">2</div>
            <h3 class="mt-3 font-heading text-lg text-text-primary">Secure</h3>
            <p class="mt-2 text-sm text-text-secondary">Local-first workflows and documented verification checks.</p>
          </Panel>
          <Panel as="article" class="p-6 text-center">
            <div class="mx-auto flex h-9 w-9 items-center justify-center rounded-full border border-accent-primary/50 text-sm font-semibold text-accent-primary">3</div>
            <h3 class="mt-3 font-heading text-lg text-text-primary">Open</h3>
            <p class="mt-2 text-sm text-text-secondary">Public repository, auditable history, and issue tracking.</p>
          </Panel>
        </div>
      </section>

      <section class="link-grid">
        <LinkCard href="https://github.com/moaiy-com/moaiy" target="_blank" analyticsEvent="github_click" title="Repository" description="Source code and issue tracker." />
        <LinkCard href="https://github.com/moaiy-com/moaiy/releases" target="_blank" analyticsEvent="download_click" title="Releases" description="Official artifacts and changelog path." />
        <LinkCard href="https://github.com/moaiy-com/moaiy/blob/main/LICENSE" target="_blank" title="MIT License" description="Open-source license terms." />
      </section>

      <Panel class="mt-12">
        <h2 class="font-heading text-2xl font-semibold text-text-primary md:text-3xl">Contact</h2>
        <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-3">
          <div class="rounded-lg border border-line-subtle bg-bg-primary/45 p-4">
            <h3 class="font-heading text-lg text-text-primary">General</h3>
            <a href="mailto:support@moaiy.com" class="mt-2 inline-flex text-sm text-accent-primary hover:underline">support@moaiy.com</a>
          </div>
          <div class="rounded-lg border border-line-subtle bg-bg-primary/45 p-4">
            <h3 class="font-heading text-lg text-text-primary">Security</h3>
            <a href="mailto:security@moaiy.com" class="mt-2 inline-flex text-sm text-accent-primary hover:underline">security@moaiy.com</a>
          </div>
          <div class="rounded-lg border border-line-subtle bg-bg-primary/45 p-4">
            <h3 class="font-heading text-lg text-text-primary">X</h3>
            <a href="https://x.com/moaiycom" target="_blank" rel="noopener noreferrer" class="mt-2 inline-flex text-sm text-accent-primary hover:underline">@moaiycom</a>
          </div>
        </div>
      </Panel>
    </div>
  </main>
</BaseLayout>
