---
import BaseLayout from '../layouts/BaseLayout.astro';

const seo = {
  title: 'Privacy Policy - Moaiy',
  description: 'Privacy policy for moaiy.com and support channels.',
  canonicalPath: '/privacy/',
  currentPage: '',
  schema: [
    {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: 'Privacy Policy - Moaiy',
      url: 'https://moaiy.com/privacy/',
    },
  ],
};
---

<BaseLayout {...seo}>
  <main class="min-h-screen bg-bg-primary px-4 py-20">
    <div class="mx-auto max-w-4xl rounded-xl border border-gray-800 bg-bg-secondary/70 p-7 md:p-8">
      <header>
        <h1 class="font-heading text-4xl font-bold text-text-primary md:text-5xl">Privacy Policy</h1>
        <p class="mt-3 text-sm text-text-tertiary">Last updated: 2026-03-31</p>
      </header>

      <div class="mt-8 space-y-6 text-sm leading-relaxed text-text-secondary">
        <section>
          <h2 class="font-heading text-2xl font-semibold text-text-primary">Scope</h2>
          <p class="mt-2">
            This policy applies to
            <a href="https://moaiy.com" class="text-accent-primary hover:underline">moaiy.com</a>
            and official support or security email channels.
          </p>
        </section>

        <section>
          <h2 class="font-heading text-2xl font-semibold text-text-primary">Website analytics</h2>
          <p class="mt-2">
            We use aggregate analytics to improve site quality. Typical data includes page views, browser info,
            and approximate region. We do not intentionally collect plaintext secrets through analytics.
          </p>
        </section>

        <section>
          <h2 class="font-heading text-2xl font-semibold text-text-primary">Support and security email</h2>
          <p class="mt-2">
            When you contact us, we process information you provide (such as email address and issue details)
            to respond and resolve requests. Do not send private keys or passwords by email.
          </p>
        </section>

        <section>
          <h2 class="font-heading text-2xl font-semibold text-text-primary">Data retention</h2>
          <p class="mt-2">
            Communication records are retained only as needed for support, security investigation, legal obligations,
            and abuse prevention.
          </p>
        </section>

        <section>
          <h2 class="font-heading text-2xl font-semibold text-text-primary">Contact</h2>
          <p class="mt-2">
            Privacy questions:
            <a href="mailto:support@moaiy.com" class="text-accent-primary hover:underline">support@moaiy.com</a>
          </p>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>
