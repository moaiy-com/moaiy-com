---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Diagnostic - Moaiy">
  <main class="min-h-screen bg-bg-primary py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-heading text-4xl font-bold text-text-primary mb-8">
        🔍 3D Scene Diagnostic
      </h1>
      
      <!-- Instructions -->
      <div class="bg-bg-secondary rounded-xl p-6 border border-gray-800 mb-8">
        <h2 class="font-heading text-2xl font-semibold text-text-primary mb-4">
          📋 How to Use
        </h2>
        <ol class="font-body text-text-secondary space-y-2 list-decimal list-inside">
          <li>Open the homepage: <a href="https://moaiy.com" class="text-accent-primary hover:underline">https://moaiy.com</a></li>
          <li>Open browser console (F12)</li>
          <li>Copy the diagnostic script below</li>
          <li>Paste and press Enter</li>
          <li>Share the output with us</li>
        </ol>
      </div>
      
      <!-- Diagnostic Script -->
      <div class="bg-bg-secondary rounded-xl p-6 border border-gray-800 mb-8">
        <h2 class="font-heading text-2xl font-semibold text-text-primary mb-4">
          📜 Diagnostic Script
        </h2>
        <button
          id="copy-button"
          class="mb-4 px-6 py-3 bg-accent-primary text-white font-semibold rounded-lg hover:bg-accent-secondary transition-colors"
        >
          📋 Copy Script
        </button>
        <div class="bg-bg-primary rounded-lg p-4 font-mono text-xs text-text-secondary overflow-x-auto whitespace-pre-wrap break-all">
          <div id="script-display"></div>
        </div>
      </div>
      
      <!-- Expected Results -->
      <div class="bg-bg-secondary rounded-xl p-6 border border-gray-800 mb-8">
        <h2 class="font-heading text-2xl font-semibold text-text-primary mb-4">
          ✅ Expected Results
        </h2>
        <ul class="font-body text-text-secondary space-y-2">
          <li>✅ Container: Found</li>
          <li>✅ Canvas: Found</li>
          <li>✅ Canvas Width: {'>'} 0</li>
          <li>✅ Canvas Height: {'>'} 0</li>
          <li>✅ WebGL: Supported</li>
          <li>✅ Three.js: Loaded</li>
        </ul>
      </div>
      
      <!-- Quick Links -->
      <div class="flex gap-4">
        <a
          href="https://moaiy.com"
          target="_blank"
          class="px-6 py-3 bg-accent-primary text-white font-semibold rounded-lg hover:bg-accent-secondary transition-colors"
        >
          Open Homepage
        </a>
        <a
          href="https://get.webgl.org/"
          target="_blank"
          class="px-6 py-3 border-2 border-accent-primary text-accent-primary font-semibold rounded-lg hover:bg-accent-primary hover:text-white transition-colors"
        >
          Test WebGL
        </a>
      </div>
    </div>
  </main>
</BaseLayout>

<script define:vars={{ scriptText }}>
  const diagnosticScript = `
console.log('🔍 Moaiy 3D Diagnostic\\n');

const results = [];

// Browser Info
results.push('=== BROWSER ===');
results.push('UA: ' + navigator.userAgent);

// WebGL
results.push('\\n=== WEBGL ===');
const canvas = document.createElement('canvas');
const gl = canvas.getContext('webgl');
results.push('WebGL: ' + (gl ? '✅ Supported' : '❌ Not Supported'));

// Canvas Status
results.push('\\n=== CANVAS ===');
const heroCanvas = document.querySelector('#hero-canvas');
const canvas3d = document.querySelector('#hero-canvas canvas');

if (heroCanvas) {
  results.push('Container: ✅ Found');
  if (canvas3d) {
    results.push('Canvas: ✅ Found');
    results.push('Width: ' + canvas3d.width);
    results.push('Height: ' + canvas3d.height);
  } else {
    results.push('Canvas: ❌ Not Found');
  }
} else {
  results.push('Container: ❌ Not Found');
}

// Component Status
results.push('\\n=== COMPONENTS ===');
const island = document.querySelector('astro-island');
results.push('astro-island: ' + (island ? '✅ Found' : '❌ Not Found'));

console.log(results.join('\\n'));
console.log('\\n✅ Diagnostic complete!');
  `.trim();
  
  // Display script
  const scriptDisplay = document.getElementById('script-display');
  scriptDisplay.textContent = diagnosticScript;
  
  // Copy button
  const copyButton = document.getElementById('copy-button');
  copyButton.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(diagnosticScript);
      copyButton.textContent = '✅ Copied!';
      setTimeout(() => {
        copyButton.textContent = '📋 Copy Script';
      }, 2000);
    } catch (err) {
      copyButton.textContent = '❌ Failed';
      setTimeout(() => {
        copyButton.textContent = '📋 Copy Script';
      }, 2000);
    }
  });
</script>
